# Frontend Firebase Phone Auth
# Create a Firebase Web App in Firebase Console and paste values here.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Backend API
VITE_API_BASE_URL=https://justeatbharat.com/api

# Optional: use Firebase Auth Emulator in development (prevents real SMS charges)
# VITE_USE_FIREBASE_AUTH_EMULATOR=true
# VITE_FIREBASE_AUTH_EMULATOR_URL=http://localhost:9099
